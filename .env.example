# === Claude / Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...

# === Scheduling ===
SCHEDULE_HOUR=10          # UTC hour to run daily (0-23)
SCHEDULE_MINUTE=0         # UTC minute
RUN_MODE=loop             # "loop" for Railway, "once" for manual runs

# === TTS ===
TTS_SPEED=1.15            # Speed multiplier (1.0 = normal, 1.2 = faster)
TTS_TLD=com               # "com" = American, "co.uk" = British, "com.au" = Australian

# === Video ===
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# === YouTube ===
YOUTUBE_ENABLED=true
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_TOKEN_JSON={"token":"...","refresh_token":"..."}
YOUTUBE_PRIVACY=public    # public, private, unlisted

# === TikTok ===
TIKTOK_ENABLED=true
TIKTOK_ACCESS_TOKEN=...   # From TikTok Developer Portal
TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE

# === Instagram ===
INSTAGRAM_ENABLED=true
INSTAGRAM_ACCESS_TOKEN=...    # Meta Graph API long-lived token
INSTAGRAM_USER_ID=...         # Your Instagram Business account ID
CDN_UPLOAD_URL=...            # Public file host upload endpoint (required for IG)
CDN_API_KEY=...               # CDN API key if needed
